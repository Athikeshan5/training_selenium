package GenericUtility;

import org.openqa.selenium.WebDriver;
import org.testng.*;
import com.aventstack.extentreports.*;

public class ListenerImplementation implements ITestListener {

    ExtentReports extent;
    
    // 🔥 ThreadLocal for parallel execution
    public static ThreadLocal<ExtentTest> test = new ThreadLocal<>();

    WebDriver driver;

    @Override
    public void onStart(ITestContext context) {
        extent = ExtentReportUtility.getInstance();
    }

    @Override
    public void onTestStart(ITestResult result) {

        ExtentTest extentTest = extent.createTest(result.getMethod().getMethodName());
        
        test.set(extentTest);   // ✅ assign to current thread
    }

    @Override
    public void onTestSuccess(ITestResult result) {
        test.get().pass("Test Passed ✅");
    }

    @Override
    public void onTestFailure(ITestResult result) {

        test.get().fail("Test Failed ❌");
        test.get().fail(result.getThrowable());

        try {
            driver = (WebDriver) result.getTestClass()
                    .getRealClass()
                    .getField("driver")
                    .get(result.getInstance());

            ScreenShotUtility s = new ScreenShotUtility(driver);
            String path = s.captureScreen(driver, result.getMethod().getMethodName());

            // 🔥 attach screenshot properly
            test.get().fail("Screenshot",
                    MediaEntityBuilder.createScreenCaptureFromPath(path).build());

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @Override
    public void onTestSkipped(ITestResult result) {
        test.get().skip("Test Skipped ⚠️");
    }

    @Override
    public void onFinish(ITestContext context) {
        extent.flush();
    }
}