package GenericUtility;

import java.io.File;
import java.io.IOException;
import java.text.SimpleDateFormat;
import java.util.Date;

import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.interactions.Actions;
import org.openqa.selenium.io.FileHandler;
import org.testng.Reporter;

import com.aventstack.extentreports.ExtentTest;
import com.aventstack.extentreports.Status;

public class ScreenShotUtility  {
  
	WebDriver driver;
	 ExtentTest test;
	public ScreenShotUtility(WebDriver driver) {
		this.driver = driver;
	}
	public String captureScreen(WebDriver driver,String testName) throws IOException {
		String timeStamp=new SimpleDateFormat("yyyy-mm-dd").format(new Date());
		String path="./reports/"+testName+timeStamp+".png";
		
	     TakesScreenshot ts=(TakesScreenshot)driver;
	     File temp = ts.getScreenshotAs(OutputType.FILE);
	     File permanent=new File(path);
	     FileHandler.copy(temp, permanent);
	     test.log(Status.INFO,path);
	     return path;
	}
	public String captureScreen(WebElement ele,String testName) throws IOException {
		String timeStamp=new SimpleDateFormat("yyyy-mm-dd").format(new Date());
		String path="./reports/"+testName+timeStamp+".png";
	     File temp = ele.getScreenshotAs(OutputType.FILE);
	     File permanent=new File(path);
	     FileHandler.copy(temp, permanent);
	     test.log(Status.INFO,path);
	     return path;
	}
}
