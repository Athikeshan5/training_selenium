package GenericUtility;

import com.aventstack.extentreports.ExtentReports;
import com.aventstack.extentreports.reporter.ExtentSparkReporter;

public class ExtentReportUtility {

	public static ExtentReports extent;
	
	public static ExtentReports ExtentInstances() {
		if(extent==null) {
			ExtentSparkReporter spark=new ExtentSparkReporter("./reports/dashboard.png");
			spark.config().setReportName("orangehrm ui automation report");
			spark.config().setDocumentTitle("Test Results");
			extent=new ExtentReports();
			extent.attachReporter(spark);
			extent.setSystemInfo("Automation tester", "athikeshan");
			extent.setSystemInfo("UI framework", "seleniumTestNG");
		}
		return extent;
	}
}
