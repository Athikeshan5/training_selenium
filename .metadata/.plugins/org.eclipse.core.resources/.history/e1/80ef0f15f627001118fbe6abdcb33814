    	fis = new FileInputStream(path);
     	wb=WorkbookFactory.create(fis);
     	sheet=wb.getSheet(sheetname);
     	row=sheet.getRow(rowno);
     	if(row==null) {
     		row=sheet.createRow(rowno);
     	}
     	col=row.createCell(cellno);
     	if(col==null) {
     		col=row.createCell(cellno);
     	}
     	
    }
