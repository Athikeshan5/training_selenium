package GenericUtility;

import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.IOException;

import org.apache.poi.EncryptedDocumentException;
import org.apache.poi.ss.usermodel.*;

public class ExcelUtility {

    String path;
    FileInputStream fis;
    FileOutputStream fos;
    Workbook wb ;
    Sheet sheet;
    Row row;
    Cell col;
    public ExcelUtility(String path) {
        this.path = path;
    }

    public Object[][] getSheetData(String sheetName) throws IOException {

         fis = new FileInputStream(path);
        wb = WorkbookFactory.create(fis);
        sheet = wb.getSheet(sheetName);

        int rows = sheet.getLastRowNum();
        int cols = sheet.getRow(0).getLastCellNum();

        Object[][] tempData = new Object[rows][cols];
        int validRowCount = 0;

        for (int i = 1; i <= rows; i++) {
            row = sheet.getRow(i);

            // Skip empty row
            if (row != null ) {

            for (int j = 1; j < cols; j++) {
            	
                col=row.getCell(j);
            	
                if(col!=null) {
                        tempData[validRowCount][j] = col.getStringCellValue();
            
                    }
            }
            validRowCount++;
            }
        }

        wb.close();
        fis.close();

        return tempData;
    }
    public void  createSheetData(String sheetname) throws EncryptedDocumentException, IOException {
    	
    	fis = new FileInputStream(path);
     	wb=WorkbookFactory.create(fis);
     	fis.close();
    	sheet=wb.createSheet(sheetname);
    	for(int i=0;i<5;i++) {
    	row=sheet.createRow(i);
    	for(int j=0;j<5;j++) {
    	col=row.createCell(j);
    	col.setCellValue(sheetname);
    	}
    	}
    	FileOutputStream fos=new FileOutputStream(path);
    	wb.write(fos);
    	wb.close();
    	fos.close();
    }
}