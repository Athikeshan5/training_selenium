package POMObjectRepository;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;
import org.openqa.selenium.support.PageFactory;

public class AddVacanciesPage {

	public WebDriver driver;

	public AddVacanciesPage(WebDriver driver) {
		this.driver = driver;
		PageFactory.initElements(driver, this);
	}

	@FindBy(xpath="//label[.='Vacancy Name']/../../child::div/input")
	private WebElement vacancyname;

	@FindBy(xpath="//label[.='Description']/../../child::div/textarea")
	private WebElement description;

	@FindBy(xpath="//label[.='Hiring Manager']/../../child::div[.='-- Select --']")
	private WebElement hiringManager;

	@FindBy(xpath="//label[.='Status']/../../child::div[.='-- Select --']")
	private WebElement status;

	@FindBy(xpath="//label[.='Job Title']/../../child::div[.='-- Select --']")
	private WebElement jobtitle;

	@FindBy(xpath="//label[.='Number of Positions']/../../child::div/input")
	private WebElement noofpositions;

	@FindBy(xpath="//p[.='Active']/..//input")
	private WebElement active;

	@FindBy(xpath="//p[.='Publish in RSS Feed and Web Page']/..//input")
	private WebElement publish;

	@FindBy(xpath="//button[.=' Cancel ']")
	private WebElement cancel;

	@FindBy(xpath="//button[.=' Save ']")
	private WebElement save;

	// ---------------- GETTERS ----------------

	public WebElement getVacancyname() {
		return vacancyname;
	}

	public WebElement getDescription() {
		return description;
	}

	public WebElement getHiringManager() {
		return hiringManager;
	}

	public WebElement getStatus() {
		return status;
	}

	public WebElement getJobtitle() {
		return jobtitle;
	}

	public WebElement getNoofpositions() {
		return noofpositions;
	}

	public WebElement getActive() {
		return active;
	}

	public WebElement getPublish() {
		return publish;
	}

	public WebElement getCancel() {
		return cancel;
	}

	public WebElement getSave() {
		return save;
	}

	// ---------------- BUSINESS LOGIC ----------------

	public void enterVacancyName(String name) {
		setVacancyname(name);
	}

	public void enterDescription(String desc) {
		setDescription(desc);
	}

	public void enterNumberOfPositions(String number) {
		setNoofpositions(number);
	}

	public void clickActive() {
		getActive().click();
	}

	public void clickPublish() {
		getPublish().click();
	}

	public void clickSave() {
		getSave().click();
	}

	public void clickCancel() {
		getCancel().click();
	}
	

	//setters
	
	public void setVacancyname(String name) {
		vacancyname.sendKeys(name);
	}

	public void setDescription(String desc) {
		description.sendKeys(desc);
	}

	public void setHiringManager() {
		hiringManager.click();
	}

	public void setStatus() {
		status.click();
	}

	public void setJobtitle() {
		jobtitle.click();
	}

	public void setNoofpositions(String number) {
		noofpositions.sendKeys(number);
	}

	public void setActive() {
		active.click();
	}

	public void setPublish() {
		publish.click();
	}

	public void setCancel() {
		cancel.click();
	}

	public void setSave() {
		save.click();
	}
	
	
	// Full form business method
	public void createVacancy(String name, String desc, String number) {
		setVacancyname(name);;
		setDescription(desc);
		setNoofpositions(number);
		getJobtitle().click();
		getHiringManager().click();
		save.click();
	}
}