//bussiness logic
public void addEmployee() {
	getAdd().click();
}
By empList = By.cssSelector(".oxd-pagination-page-item.oxd-pagination-page-item--page");
By cardEmpList = By.cssSelector(".card-center");

public boolean listEmployeeButton(String empname) {

    List<WebElement> page = driver.findElements(cardEmpList);

    for (WebElement w : page) {
        w.click();

        List<WebElement> empnamelist = driver.findElements(empList);

        if (empnamelist.size() > 0) {
            if (empnamelist.get(0).getText().contains(empname)) {
                return true;
            }
        }
    }

    return false;
}
	
