package POMObjectRepository;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;
import org.openqa.selenium.support.PageFactory;

public class PIMPage {
public WebDriver driver;
public PIMPage(WebDriver driver) {
	this.driver=driver;
	PageFactory.initElements(driver, this);
}
@FindBy(xpath="//span[.='Configuration ']")
WebElement configuration;

@FindBy(xpath="//a[.='Optional Fields']")
WebElement optioanalFields;

@FindBy(xpath="//a[.='Custom Fields']")
WebElement customFields;

@FindBy(xpath="//a[.='Data Import']")
WebElement dataImport;

@FindBy(xpath="//a[.='Reporting Methods']")
WebElement ReportingMethods;

@FindBy(xpath="//a[.='Termination Reasons']")
WebElement TerminationReasons;

@FindBy(xpath="//a[.='Employee List']")
WebElement EmployeeList;

@FindBy(xpath="//span[.='More ']")
WebElement More;

@FindBy(xpath="//a[.='Add Employee ']")
WebElement addEmployee;

@FindBy(xpath="//a[.='Reports ']")
WebElement reports;

@FindBy(css="[class='oxd-icon bi-caret-up-fill']")
WebElement EmpInfoDropDown;

@FindBy(xpath="//label[.='Employee Name']/following::input[1]")
WebElement EmployeeName;

@FindBy(xpath="//label[.='Employee Id']/following::input[1]")
WebElement EmployeeId;

@FindBy(xpath="//label[.='Employment Status']/following::div[1]")
WebElement EmploymentStatus;


}
