package GenericUtility;

import java.io.FileInputStream;
import java.io.IOException;
import java.time.Duration;
import java.util.Properties;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.testng.annotations.AfterClass;
import org.testng.annotations.BeforeClass;
import org.testng.annotations.BeforeMethod;

import POMObjectRepository.AddEmployee;
import POMObjectRepository.DashboardPage;
import POMObjectRepository.LoginPage;
import POMObjectRepository.PIMPage;

public class BaseClass {
	public WebDriver driver;
	public WebDriverWait ww;
	@BeforeClass
public void BeforeClass() {
	
	 
     ChromeOptions op=new ChromeOptions();
     op.addArguments("--incognito");
     driver=new ChromeDriver(op);
     driver.manage().window().maximize();
     driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(20));
    
}
	@BeforeMethod
	public void beforemethod() throws IOException {
		FileInputStream fs=new FileInputStream("./src/test/resources/orangehrmCommonData/parameterizaionPropertiesFile.properties");
		Properties prop=new Properties();
		prop.load(fs);
		LoginPage lp=new LoginPage(driver);
		ww=new WebDriverWait(driver, Duration.ofSeconds(20));
		lp.url(prop.getProperty("url"));
		lp.enterCredational(prop.getProperty("username"),prop.getProperty("password"));
	}
	@AfterClass
	public  void afterclass() {
		driver.quit();
	}
}
